# EditorConfig helps maintain consistent coding styles for multiple developers
# working on the same project across various editors and IDEs.
# editorconfig.org

root = true

# All files
[*]
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# XML and FXML files - explicitly UTF-8 without BOM
[*.{xml,fxml,css}]
indent_size = 2
charset = utf-8

# Java files
[*.java]
indent_size = 4
charset = utf-8

# Properties files
[*.properties]
charset = utf-8
