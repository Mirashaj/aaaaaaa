<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="theknife.client.controller.LoginController" styleClass="tk-root">


   <top>
      <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="tk-welcome-navbar">
         <children>
            <VBox spacing="2.0" style="-fx-padding: 6 28 0 12">
            <StackPane styleClass="tk-welcome-brand-badge">
               <children>
                  <Label text="TK" styleClass="tk-welcome-brand-badge-text" />
               </children>
            </StackPane>
            </VBox>
            
            <HBox style="-fx-padding: 10 0 0 0">
               <children>
                    <Label text="TheKnife" styleClass="tk-welcome-brand-text" />
               </children>
            </HBox>  

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308">
               <children>
                  <Hyperlink text="← Indietro" onAction="#handleIndietro" styleClass="tk-field-label" />
               </children>
            </HBox>

         </children>
      </HBox>
   </top>

   <center>
      <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-faint-focus-color: transparent; -fx-focus-color: transparent;">
         <content>
            <VBox alignment="CENTER" prefHeight="700.0" prefWidth="800.0" spacing="18.0" styleClass="tk-root">
               <children>
                  <VBox alignment="CENTER" spacing="15.0" styleClass="tk-login-shell" maxWidth="430.0">
                     <children>
                        <VBox alignment="CENTER" spacing="15.0" styleClass="tk-card tk-login-card" prefWidth="420.0" maxWidth="420.0">
                           <children>
                              <VBox spacing="20.0" styleClass="tk-login-panel">
                                 <VBox alignment="CENTER" spacing="6.0">
                                    <children>
                                       <Label text="Accedi" styleClass="tk-form-title" textAlignment="CENTER" alignment="CENTER">
                                          <font>
                                             <Font name="System" size="22.0" />
                                          </font>
                                       </Label>
                                       <Label text="Benvenuto su TheKnife" styleClass="tk-field-label" textAlignment="CENTER" alignment="CENTER" />
                                    </children>
                                 </VBox>
                                 <children>
                                    <VBox spacing="15.0">
                                       <children>
                                          <VBox spacing="6.0">
                                             <children>
                                                <Label text="✉ Email" styleClass="tk-field-label" />
                                                <TextField fx:id="tfEmail" promptText="tua@email.com" styleClass="tk-input" />
                                             </children>
                                          </VBox>
                                          <VBox spacing="6.0">
                                             <children>
                                                <Label text="🔒 Password" styleClass="tk-field-label" />
                                                <PasswordField fx:id="pfPassword" promptText="••••••••" styleClass="tk-input" />
                                             </children>
                                          </VBox>
                                       </children>
                                    </VBox>
                                 </children>
                              </VBox>
                              <Label fx:id="lblErrore" styleClass="tk-error-label" />
                              <Button fx:id="btnLogin" mnemonicParsing="false" onAction="#handleLogin" text="Accedi" styleClass="tk-register-button,primary" prefWidth="200.0" />
                              <HBox alignment="CENTER" spacing="5.0">
                                 <children>
                                    <Label text="Non hai un account?" style="-fx-text-fill: #888888; -fx-font-size: 12px;" />
                                    <Hyperlink text="Registrati" onAction="#handleRegistrati" styleClass="tk-register-link" />
                                 </children>
                              </HBox>
                           </children>
                           <padding>
                              <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                           </padding>
                        </VBox>
                     </children>
                  </VBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
