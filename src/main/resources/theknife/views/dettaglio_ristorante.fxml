<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="800.0" styleClass="tk-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="theknife.client.controller.DettaglioRistoranteController">
   <top>
      <VBox BorderPane.alignment="CENTER" spacing="12.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="12.0">
               <children>
                  <VBox spacing="2.0" style="-fx-padding: 0 28 0 0">
                     <children>
                        <StackPane styleClass="tk-welcome-brand-badge">
                           <children>
                              <Label text="TK" styleClass="tk-welcome-brand-badge-text" />
                           </children>
                        </StackPane>
                     </children>
                  </VBox>
                  <HBox alignment="CENTER_LEFT" spacing="8.0">
                     <children>
                        <Button fx:id="btnNavHome" mnemonicParsing="false" onAction="#handleHome" text="Home" styleClass="tk-nav-item" />
                        <Button fx:id="btnNavSecondary" mnemonicParsing="false" onAction="#handlePreferiti" text="Favorites" styleClass="tk-nav-item" />
                        <Button fx:id="btnNavThird" mnemonicParsing="false" onAction="#handleMieRecensioni" text="Reviews" styleClass="tk-nav-item" />
                        <Button fx:id="btnNavFourth" mnemonicParsing="false" onAction="#handlePrenotazioni" text="Bookings" styleClass="tk-nav-item" />
                     </children>
                  </HBox>

            <Region HBox.hgrow="ALWAYS" />

                  <HBox>
                     <children>
                        <MenuButton fx:id="accountMenuButton" mnemonicParsing="false" styleClass="tk-account-menu" />
                     </children>
                  </HBox>
               </children>
            </HBox>
            <VBox spacing="12.0" styleClass="tk-hero">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="12.0">
                     <children>
                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label fx:id="lblNome" styleClass="tk-screen-title" text="Restaurant name" />
                              <Label fx:id="lblCitta" styleClass="tk-text-secondary" text="City" />
                           </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER_RIGHT" spacing="5.0" fx:id="hboxTopRating" visible="true" managed="true">
                          <children>
                            <Label fx:id="lblAvgRatingTop" styleClass="tk-card-title-white" text="" />
                            <Label fx:id="lblAvgStarsTop" styleClass="tk-stars-white" text="" />
                          </children>
                        </HBox>
                     </children>
                  </HBox>
                  <Label fx:id="lblIndirizzo" styleClass="tk-text-secondary" text="Address" />
                  <HBox spacing="8.0">
                     <children>
                        <Label fx:id="lblCucina" styleClass="tk-badge" text="Cuisine" />
                        <Label fx:id="lblPrezzo" styleClass="tk-badge" text="Price" />
                        <Label fx:id="lblDelivery" styleClass="tk-badge" text="Delivery" />
                        <Label fx:id="lblPrenotazione" styleClass="tk-badge" text="Booking" />
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="16.0" left="24.0" right="24.0" top="16.0" />
               </padding>
            </VBox>
         </children>
         <padding>
            <Insets bottom="18.0" left="24.0" right="24.0" top="18.0" />
         </padding>
      </VBox>
   </top>

   <center>
      <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="tk-content-scroll">
         <content>
            <HBox spacing="28.0" styleClass="tk-detail-layout">
               <children>
                  <VBox spacing="12.0" styleClass="tk-detail-left" fillWidth="false">
                     <children>
                        <Label styleClass="tk-section-title" text="INFORMATION" />
                          <HBox spacing="8.0" fillHeight="true" prefWidth="448.0">
                           <children>
                                <VBox prefWidth="220.0" spacing="8.0" styleClass="tk-metric-card">
                                 <children>
                                    <Label styleClass="tk-text-secondary" text="Address" />
                                    <Label fx:id="lblIndirizzoInfo" maxWidth="220.0" styleClass="tk-card-title" wrapText="true" />
                                 </children>
                                </VBox>
                                <VBox prefWidth="220.0" spacing="8.0" styleClass="tk-metric-card">
                                  <children>
                                    <Label styleClass="tk-text-secondary" text="Cuisine" />
                                    <Label fx:id="lblCucinaInfo2" maxWidth="220.0" styleClass="tk-card-title" wrapText="true" />
                                  </children>
                                </VBox>
                           </children>
                        </HBox>

                        <HBox spacing="8.0" fillHeight="true" prefWidth="448.0">
                           <children>
                              <VBox prefWidth="220.0" spacing="8.0" styleClass="tk-metric-card">
                                  <children>
                                    <Label styleClass="tk-text-secondary" text="City" />
                                    <Label fx:id="lblCittaInfo" maxWidth="220.0" styleClass="tk-card-title" wrapText="true" />
                                 </children>
                              </VBox>
                              <VBox prefWidth="220.0" spacing="8.0" styleClass="tk-metric-card">
                                 <children>
                                    <Label styleClass="tk-text-secondary" text="Average price" />
                                    <Label fx:id="lblPrezzoInfo2" maxWidth="220.0" styleClass="tk-card-title" wrapText="true" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>

                        <VBox spacing="8.0" styleClass="tk-map-card">
                           <children>
                              <Region prefHeight="200.0" HBox.hgrow="ALWAYS" />
                              <HBox spacing="8.0" alignment="CENTER_LEFT">
                                 <children>
                                    <Label styleClass="tk-text-secondary" />
                                    <Label fx:id="lblCoordinate" styleClass="tk-text-secondary" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </VBox>

                  <Region minWidth="1.0" maxWidth="1.0" prefWidth="1.0" styleClass="tk-detail-divider" />

                  <VBox spacing="12.0" minWidth="600.0" styleClass="tk-detail-main">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                           <children>
                              <Label styleClass="tk-section-title" text="REVIEWS" />
                              <Region HBox.hgrow="ALWAYS" />
                           </children>
                        </HBox>

                        <VBox spacing="12.0" styleClass="tk-card">
                           <children>
                              <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" prefHeight="320.0" minHeight="320.0" maxHeight="320.0" >
                                 <content>
                                    <VBox spacing="12.0" fx:id="vboxRecensioni">
                                       <padding>
                                          <Insets right="10.0" />
                                       </padding>
                                    </VBox>
                                 </content>
                              </ScrollPane>
                           </children>
                        </VBox>

                        <Label fx:id="lblLoginPrompt" styleClass="tk-text-secondary" />

                        <VBox fx:id="vboxFormRecensione" spacing="12.0" styleClass="tk-card tk-review-module">
                                 <children>
                                    <Label styleClass="tk-section-title" text="Write a review" />
                                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                                       <children>
                                          <HBox fx:id="starsContainer" spacing="6.0" alignment="CENTER_LEFT">
                                            <children>
                                              <Button fx:id="star1" text="☆" styleClass="tk-star-button" />
                                              <Button fx:id="star2" text="☆" styleClass="tk-star-button" />
                                              <Button fx:id="star3" text="☆" styleClass="tk-star-button" />
                                              <Button fx:id="star4" text="☆" styleClass="tk-star-button" />
                                              <Button fx:id="star5" text="☆" styleClass="tk-star-button" />
                                              </children>
                                          </HBox>
                                        </children>
                                    </HBox>
                                  <TextArea fx:id="txtTestoRecensione" prefRowCount="4" promptText="Describe your experience..." styleClass="tk-input" wrapText="true" />

                              <HBox alignment="CENTER_RIGHT" spacing="8.0">
                                 <children>
                                    <Button mnemonicParsing="false" onAction="#handleAnnullaRecensione" text="Cancel" styleClass="tk-btn-secondary" />
                                    <Button fx:id="btnInviaRecensione" mnemonicParsing="false" onAction="#handleInviaRecensione" text="Submit review" styleClass="tk-btn-primary" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </VBox>

                  <Region minWidth="1.0" maxWidth="1.0" prefWidth="1.0" styleClass="tk-detail-divider" />

                  <VBox spacing="12.0" prefWidth="360.0" styleClass="tk-detail-sidebar">
                     <children>
                        <Button fx:id="btnPrenota" mnemonicParsing="false" onAction="#handlePrenota" text="Book a table" prefWidth="450.0" styleClass="tk-btn-primary" />
                        <Button fx:id="btnPreferito" mnemonicParsing="false" onAction="#handlePreferito" text="Add to favorites" prefWidth="400.0" styleClass="tk-btn-secondary" />

                        <VBox spacing="16.0" styleClass="tk-card">
                           <children>
                              <Label styleClass="tk-section-title" text="Average rating" />
                              <HBox alignment="CENTER_LEFT" spacing="8.0">
                                 <children>
                                    <Label fx:id="lblAvgRating" styleClass="tk-card-title" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblReviewCount" styleClass="tk-text-secondary" text="124" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>

                        <VBox spacing="16.0" styleClass="tk-card">
                           <children>
                              <Label styleClass="tk-section-title" text="Services" />
                              <Label fx:id="lblDeliveryInfo" styleClass="tk-text-secondary" text="Delivery available" />
                              <Label fx:id="lblPrenotazioneInfo" styleClass="tk-text-secondary" text="Booking available" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
