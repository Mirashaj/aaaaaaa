<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1100.0" styleClass="tk-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="theknife.client.controller.AggiungiRistoranteController">
   <top>
      <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="tk-welcome-navbar">
         <children>
            <VBox spacing="2.0" style="-fx-padding: 6 28 0 12">
               <children>
                  <StackPane styleClass="tk-welcome-brand-badge">
                     <children>
                        <Label text="TK" styleClass="tk-welcome-brand-badge-text" />
                     </children>
                  </StackPane>
               </children>
            </VBox>
            <HBox alignment="CENTER_LEFT" spacing="8.0">
               <children>
                  <Button fx:id="btnNavHome" mnemonicParsing="false" onAction="#handleAnnulla" text="Dashboard" styleClass="tk-nav-item" />
                  <Button fx:id="btnNavRestaurants" mnemonicParsing="false" text="Restaurants" styleClass="tk-nav-active" />
                  <Button fx:id="btnNavReviews" mnemonicParsing="false" text="Review" styleClass="tk-nav-item" />
               </children>
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <Label text="New restaurant" styleClass="tk-field-label2" />
         </children>
      </HBox>
   </top>
   <center>
      <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="tk-content-scroll">
         <content>
            <VBox spacing="18.0" styleClass="tk-detail-layout">
               <children>
                  <VBox spacing="10.0" styleClass="tk-hero">
                     <children>
                        <Label text="Add restaurant" styleClass="tk-screen-title" />
                        <Label text="Fill all required fields to register your venue." styleClass="tk-text-secondary" />
                     </children>
                     <padding>
                        <Insets bottom="16.0" left="24.0" right="24.0" top="16.0" />
                     </padding>
                  </VBox>

                  <VBox spacing="16.0" styleClass="tk-card tk-owner-form-card">
                     <children>
                        <Label text="GENERAL INFORMATION" styleClass="tk-field-label2" />
                        <GridPane hgap="16.0" vgap="14.0">
                           <children>
                              <VBox GridPane.columnSpan="3" spacing="6.0">
                                 <children>
                                    <Label text="Restaurant name *" styleClass="tk-field-label" />
                                    <TextField fx:id="txtNome" promptText="e.g. Osteria del Borgo" styleClass="tk-input" />
                                 </children>
                              </VBox>
                              <VBox GridPane.rowIndex="1" GridPane.columnSpan="2" spacing="6.0">
                                 <children>
                                    <Label text="Address *" styleClass="tk-field-label" />
                                    <TextField fx:id="txtIndirizzo" promptText="Via Roma 12" styleClass="tk-input" />
                                 </children>
                              </VBox>
                              <VBox GridPane.rowIndex="1" GridPane.columnIndex="2" spacing="6.0">
                                 <children>
                                    <Label text="Cuisine type" styleClass="tk-field-label" />
                                    <TextField fx:id="txtCucina" promptText="e.g. Italian" styleClass="tk-input" />
                                 </children>
                              </VBox>
                              <VBox GridPane.rowIndex="2" GridPane.columnIndex="0" spacing="6.0">
                                 <children>
                                    <Label text="City *" styleClass="tk-field-label" />
                                    <TextField fx:id="txtCitta" promptText="Milan" styleClass="tk-input" />
                                 </children>
                              </VBox>
                              <VBox GridPane.rowIndex="2" GridPane.columnIndex="1" spacing="6.0">
                                 <children>
                                    <Label text="Country *" styleClass="tk-field-label" />
                                    <TextField fx:id="txtNazione" promptText="Italy" styleClass="tk-input" />
                                 </children>
                              </VBox>
                              <VBox GridPane.rowIndex="2" GridPane.columnIndex="2" spacing="6.0">
                                 <children>
                                    <Label text="Average price (€) *" styleClass="tk-field-label" />
                                    <TextField fx:id="txtPrezzo" promptText="45" styleClass="tk-input" />
                                 </children>
                              </VBox>
                              <VBox GridPane.rowIndex="3" GridPane.columnIndex="0" spacing="6.0">
                                 <children>
                                    <Label text="Latitude *" styleClass="tk-field-label" />
                                    <TextField fx:id="txtLatitudine" promptText="45.4654" styleClass="tk-input" />
                                 </children>
                              </VBox>
                              <VBox GridPane.rowIndex="3" GridPane.columnIndex="1" spacing="6.0">
                                 <children>
                                    <Label text="Longitude *" styleClass="tk-field-label" />
                                    <TextField fx:id="txtLongitudine" promptText="9.1859" styleClass="tk-input" />
                                 </children>
                              </VBox>
                           </children>
                        </GridPane>

                        <VBox spacing="8.0">
                           <children>
                              <Label text="AVAILABLE SERVICES" styleClass="tk-field-label2" />
                              <HBox spacing="18.0">
                                 <children>
                                    <CheckBox fx:id="chkDelivery" mnemonicParsing="false" text="Delivery" styleClass="tk-text-secondary" />
                                    <CheckBox fx:id="chkPrenotazione" mnemonicParsing="false" text="Online booking" styleClass="tk-text-secondary" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>

                        <Label fx:id="lblErrore" text="" styleClass="tk-text-error" />

                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#handleAnnulla" text="Cancel" styleClass="tk-btn-secondary" />
                              <Button mnemonicParsing="false" onAction="#handleSalva" text="Save restaurant" styleClass="tk-btn-primary" />
                           </children>
                        </HBox>
                     </children>
                     <padding>
                        <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
                     </padding>
                  </VBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
